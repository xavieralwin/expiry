# Use Node.js for running the backend API
FROM node:20-alpine

WORKDIR /app

# Install only production dependencies (skip frontend dev tools)
COPY package*.json ./
RUN npm ci --omit=dev

# Copy the server directory
COPY server/ ./server/

# Expose the API port
EXPOSE 8080

# Run the Node Express server directly
CMD ["node", "server/index.js"]
